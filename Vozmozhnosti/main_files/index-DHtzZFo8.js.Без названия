  box-sizing: border-box;
}
.design-editor-button-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 4px;
  color: rgba(0, 0, 0, 0.85);
  border: 1px solid #e9ecf0;
  background-color: #fafafa; /* #FAFAFA */
  border-radius: 10px;
  box-shadow: 0px 4px 20px 0px rgba(0, 0, 0, 0.15);
}
.design-editor-button-item {
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
  width: 100%;
  padding: 6px;

  border-radius: 6px;
}
.design-editor-button-item:hover {
  background-color: rgba(0, 0, 0, 0.08);
}
.design-editor-button-item svg {
  width: 16px;
  height: 16px;
}
.button-divider {
  width: 1px;
  height: 20px;
  background-color: #dadee5;
}
